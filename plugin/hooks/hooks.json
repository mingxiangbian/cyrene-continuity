{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'exec \"$HOME/.cyrene/codex/bin/cyrene-continuity\" codex hook session-start'",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'exec \"$HOME/.cyrene/codex/bin/cyrene-continuity\" codex hook user-prompt-submit'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'exec \"$HOME/.cyrene/codex/bin/cyrene-continuity\" codex hook post-tool-use'",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'exec \"$HOME/.cyrene/codex/bin/cyrene-continuity\" codex hook stop'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
